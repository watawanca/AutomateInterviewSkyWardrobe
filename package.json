{
  "name": "skywardrobe",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "weather:run": "tsx Utils/OpenMeteo.ts",
    "weather:update": "tsx Utils/OMSummary.ts --write",
    "weather:watch": "tsx watch Utils/OpenMeteo.ts",
    "build": "tsc -p tsconfig.json",
    "build:exe": "node tools/pkg/prepare-assets.mjs && tsup tools/pkg/launcher.ts --format cjs --target node18 --out-dir dist-exe --clean && pkg dist-exe/launcher.cjs --targets node18-win-x64 --output dist-exe/SkyWardrobe.exe",
    "dev:backend": "tsx watch src/backend.ts",
    "build:backend": "tsc -p tsconfig.json --outDir dist",
    "ui": "tsx Utils/UiCli.ts",
    "start": "node dist/backend.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "openmeteo": "latest"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "pkg": "^5.8.1",
    "tsup": "^8.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vitest": "^2.1.8"
  },
  "pkg": {
    "assets": [
      "tools/pkg/assets/**/*"
    ]
  }
}
