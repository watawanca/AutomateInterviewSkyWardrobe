{
  "name": "skywardrobe",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "weather:run": "tsx Utils/OpenMeteo.ts",
    "weather:summary": "tsx Utils/OpenMeteoFilteredSummary.ts",
    "weather:watch": "tsx watch Utils/OpenMeteo.ts",
    "build": "tsc -p tsconfig.json",
    "dev:backend": "tsx watch src/backend.ts",
    "build:backend": "tsc -p tsconfig.json --outDir dist",
    "start": "node dist/backend.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "openmeteo": "latest"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vitest": "^2.1.8"
  }
}
